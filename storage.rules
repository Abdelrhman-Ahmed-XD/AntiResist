rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Gallery images — public read, signed-in write
    // The admin dashboard (AdminRoute) enforces admin-only access at the UI
    // layer; requiring auth here prevents anonymous uploads from outside the app.
    match /gallery/{fileName} {
      allow read:   if true;
      allow create: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
