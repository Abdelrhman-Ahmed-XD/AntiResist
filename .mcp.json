{
  "mcpServers": {
    "serena": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:\\MCP-Servers\\serena",
        "serena",
        "start-mcp-server",
        "--project",
        "C:\\Work Front-End\\AntiResist",
        "--transport",
        "stdio"
      ]
    },
    "filesystem": {
      "command": "node",
      "args": [
        "C:\\MCP-Servers\\servers\\src\\filesystem\\dist\\index.js",
        "C:\\Work Front-End\\AntiResist"
      ]
    },
    "agent-browser": {
      "command": "node",
      "args": [
        "C:\\MCP-Servers\\agent-browser-main\\bin\\agent-browser.js"
      ]
    },
    "chrome-devtools": {
      "command": "node",
      "args": [
        "C:\\MCP-Servers\\chrome-devtools-mcp\\build\\src\\bin\\chrome-devtools-mcp.js"
      ]
    },
    "dbhub": {
      "command": "node",
      "args": [
        "C:\\MCP-Servers\\dbhub\\dist\\index.js"
      ],
      "env": {
        "DSN": ""
      }
    },
    "sentry": {
      "command": "node",
      "args": [
        "C:\\MCP-Servers\\sentry-mcp\\packages\\mcp-server\\dist\\index.js"
      ],
      "env": {
        "SENTRY_AUTH_TOKEN": "",
        "SENTRY_ORG": ""
      }
    }
  }
}
